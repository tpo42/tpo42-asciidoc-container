#!/bin/bash
# ADCW - AsciiDoc Container Build Wrapper
# Build container with proper user mapping and error handling

set -e
set -u
set -o pipefail

# Resolve lib directory — ADC_PROJECT_HOME (contributor/brew) or relative to this script
: "${ADC_PROJECT_HOME:=$(realpath "$(dirname "$(dirname "${BASH_SOURCE[0]}")")")}"
_ADCW_LIB_DIR="${ADC_PROJECT_HOME}/lib"

if [[ ! -f "${_ADCW_LIB_DIR}/adcw-common.bash" ]]; then
    echo "Error: Cannot find lib/adcw-common.bash (ADC_PROJECT_HOME=${ADC_PROJECT_HOME})" >&2
    exit 1
fi

# shellcheck source=../lib/adcw-common.bash
source "${_ADCW_LIB_DIR}/adcw-common.bash"

_adcw_detect_runner
_adcw_detect_tag

CONTAINER_IMAGE="tpo42/adoc:${CONTAINER_TAG}"

echo "Building ADCW Container: ${CONTAINER_IMAGE}"
echo "   Using: ${_ADCW_CONTAINER_RUNNER_BIN}"

${_ADCW_CONTAINER_RUNNER_BIN} buildx build \
    --build-arg=USER_UID="$(id -u)" \
    --build-arg=USER_GID="$(id -g)" \
    --build-arg=USER_NAME="$(id -un)" \
    --build-arg=USER_GROUP_NAME="$(id -gn)" \
    --file "${ADC_PROJECT_HOME}/container/Containerfile" \
    --tag="${CONTAINER_IMAGE}" \
    "${ADC_PROJECT_HOME}/container"

echo "Container built successfully!"
echo ""
echo "Usage:"
echo "  ./bin/adcw shell                                           # Interactive shell"
echo "  ./bin/adcw flatten -i mydoc.adoc -o mydoc-flattened.adoc   # Flatten includes"
echo "  ./bin/adcw validate -i mydoc.adoc                          # Validate syntax"
echo ""
echo "Container: ${CONTAINER_IMAGE}"
